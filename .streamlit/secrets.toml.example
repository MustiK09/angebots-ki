# VORLAGE – nicht mit echten Werten committen!
#
# Auf Streamlit Community Cloud:
#   App-Einstellungen  ->  "Secrets"  ->  diesen Inhalt (mit echten Werten) einfügen.
#
# Lokal (optional): diese Datei nach ".streamlit/secrets.toml" kopieren und ausfüllen.
# Sie ist in .gitignore ausgeschlossen.

ANTHROPIC_API_KEY = "sk-ant-..."

# Optionaler Passwortschutz für die öffentliche Demo.
# Leer lassen oder Zeile entfernen = kein Passwortschutz.
APP_PASSWORD = "dein-demo-passwort"

# Optional: Produktdaten & Vorlagen aus AWS S3 (Anleitung: AWS_SETUP.md).
# Ohne diese Werte nutzt die App weiter Upload/Beispieldaten.
# AWS_ACCESS_KEY_ID = "AKIA..."
# AWS_SECRET_ACCESS_KEY = "..."
# AWS_DEFAULT_REGION = "eu-central-1"
# S3_BUCKET = "angebots-ki-deinname"
